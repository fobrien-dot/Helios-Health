---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const conditions = await getCollection("conditions");

const categoryLabels: Record<string, string> = {
  "rare-disease": "Rare disease",
  cancer: "Cancer",
  "chronic-autoimmune": "Chronic & autoimmune",
};

const categoryTagClass: Record<string, string> = {
  "rare-disease": "tag category-tag tag--rare-disease",
  cancer: "tag category-tag tag--cancer",
  "chronic-autoimmune": "tag category-tag tag--chronic-autoimmune",
};

const categoriesPresent = [...new Set(conditions.map((c) => c.data.category))];
---
<BaseLayout
  title="Home"
  description="Helios pairs plain-language overviews with peer-reviewed research, lifestyle guidance, and treatment information for people newly diagnosed with a medical condition."
>
  <div class="hero-band">
    <div class="container condition-hero">
      <h1>Understand your diagnosis, clearly.</h1>
      <p class="condition-hero__summary">
        Helios pairs a plain-language overview with a peer-reviewed research
        library, lifestyle guidance, and treatment information &mdash; all
        clearly sourced, never scraped from forums or anecdotes.
      </p>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <h2>Condition guides</h2>
      <div class="condition-search">
        <input
          type="search"
          id="condition-search-input"
          class="search-input"
          placeholder="Search by condition, symptom, or feeling — e.g. “blood in urine”"
          aria-label="Search conditions"
        />
        <div class="category-filters" role="group" aria-label="Filter by category">
          <button type="button" class="category-filter is-active" data-category="all">All</button>
          {
            categoriesPresent.map((category) => (
              <button type="button" class="category-filter" data-category={category}>
                {categoryLabels[category]}
              </button>
            ))
          }
        </div>
      </div>
      <div class="condition-grid" id="condition-grid">
        {
          conditions.map((condition) => (
            <a
              class="card condition-card"
              href={`${import.meta.env.BASE_URL}conditions/${condition.id}/`}
              data-category={condition.data.category}
              data-search={[
                condition.data.name,
                condition.data.shortName,
                condition.data.summary,
                condition.data.alsoKnownAs.join(" "),
                condition.data.symptoms.join(" "),
              ]
                .join(" ")
                .toLowerCase()}
            >
              <span class="tag">{condition.data.shortName}</span>
              <span class={categoryTagClass[condition.data.category]}>
                {categoryLabels[condition.data.category]}
              </span>
              <h3>{condition.data.name}</h3>
              <p>{condition.data.summary}</p>
              <span class="condition-card__cta">Read the guide &rarr;</span>
            </a>
          ))
        }
      </div>
      <p class="condition-grid-empty" id="condition-grid-empty" hidden>
        No conditions match your search yet — try a different term.
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById("condition-search-input") as HTMLInputElement | null;
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>(".category-filter"));
  const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>(".condition-card"));
  const emptyMessage = document.getElementById("condition-grid-empty");
  let activeCategory = "all";

  function applyFilters() {
    const query = (input?.value || "").trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesQuery = query === "" || (card.dataset.search || "").includes(query);
      const matchesCategory = activeCategory === "all" || card.dataset.category === activeCategory;
      const visible = matchesQuery && matchesCategory;
      card.style.display = visible ? "" : "none";
      if (visible) visibleCount += 1;
    });

    if (emptyMessage) emptyMessage.hidden = visibleCount !== 0;
  }

  input?.addEventListener("input", applyFilters);

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      activeCategory = button.dataset.category || "all";
      buttons.forEach((b) => b.classList.toggle("is-active", b === button));
      applyFilters();
    });
  });
</script>
