---
import { getCollection } from "astro:content";
import ConditionLayout from "../../layouts/ConditionLayout.astro";

export async function getStaticPaths() {
  const conditions = await getCollection("conditions");
  return conditions.map((condition) => ({
    params: { slug: condition.id },
    props: { condition },
  }));
}

const { condition } = Astro.props;
const data = condition.data;
---
<ConditionLayout
  name={data.name}
  shortName={data.shortName}
  alsoKnownAs={data.alsoKnownAs}
  summary={data.summary}
  category={data.category}
  overview={data.overview}
  research={data.research}
  lifestyle={data.lifestyle}
  treatments={data.treatments}
  questionsToAsk={data.questionsToAsk}
  lastReviewed={data.lastReviewed}
  nextReviewDue={data.nextReviewDue}
  changelog={data.changelog}
  disclaimer={data.disclaimer}
/>
