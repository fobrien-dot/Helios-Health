<header class="site-header">
  <div class="container site-header__row">
    <div>
      <a class="site-header__brand" href={import.meta.env.BASE_URL}>
        <svg class="site-header__mark" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="5" fill="currentColor" />
          <g stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
            <line x1="12" y1="1.5" x2="12" y2="4.5" />
            <line x1="12" y1="19.5" x2="12" y2="22.5" />
            <line x1="1.5" y1="12" x2="4.5" y2="12" />
            <line x1="19.5" y1="12" x2="22.5" y2="12" />
            <line x1="4.4" y1="4.4" x2="6.5" y2="6.5" />
            <line x1="17.5" y1="17.5" x2="19.6" y2="19.6" />
            <line x1="4.4" y1="19.6" x2="6.5" y2="17.5" />
            <line x1="17.5" y1="6.5" x2="19.6" y2="4.4" />
          </g>
        </svg>
        <span class="site-header__name">Helios</span>
      </a>
      <p class="site-header__tagline">
        Clear, sourced information for people newly diagnosed with a medical condition.
      </p>
    </div>
    <nav class="site-header__nav" aria-label="Primary">
      <a href={`${import.meta.env.BASE_URL}sourcing/`}>How we source</a>
      <a href={`${import.meta.env.BASE_URL}about/`}>About</a>
    </nav>
  </div>
</header>
