---
interface StudyEntry {
  title: string;
  authors: string;
  journal: string;
  year: number;
  url: string;
  summary: string;
  sourceType: "peer-reviewed-journal" | "institution" | "advocacy-org";
}

interface Props {
  studies: StudyEntry[];
}

const { studies } = Astro.props;

const sourceTypeLabels: Record<StudyEntry["sourceType"], string> = {
  "peer-reviewed-journal": "Peer-reviewed journal",
  institution: "Recognized institution",
  "advocacy-org": "Patient-advocacy org",
};
---
<section class="section" id="research" aria-labelledby="research-heading">
  <div class="container">
    <p class="section__eyebrow"><span class="section__eyebrow-index">02</span> · Research library</p>
    <span class="section__icon section__icon--research" aria-hidden="true">🔬</span>
    <h2 id="research-heading">Research library</h2>
    <p>Peer-reviewed studies, summarized in plain language.</p>
    {
      studies.map((study) => (
        <article class="card">
          <p class="study-badge">
            {study.journal} · {study.year}
          </p>
          <span class="source-type-badge">{sourceTypeLabels[study.sourceType]}</span>
          <h3>{study.title}</h3>
          <p class="card__meta">{study.authors}</p>
          <p>{study.summary}</p>
          <a class="card__link" href={study.url} target="_blank" rel="noopener noreferrer">
            Read the study &rarr;
          </a>
        </article>
      ))
    }
  </div>
</section>
